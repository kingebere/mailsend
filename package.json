{
  "name": "mailsend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:typegen && npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:typegen && npm run cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv",
    "db:migrate:local": "wrangler d1 migrations apply mailer --local",
    "db:migrate:remote": "wrangler d1 migrations apply mailer --remote"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.5.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.44.6",
    "jose": "^5.6.3",
    "lucide-react": "^0.400.0",
    "next": "16.2.2",
    "nodemailer": "^6.9.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
