# .env.local — copy this to .env.local and fill in your values

# Database (SQLite for local dev, switch to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# Auth secret — generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Your app's public URL (used for unsubscribe links, webhook URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: set default AWS credentials here, or users set them in the dashboard
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
